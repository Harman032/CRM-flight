{
    "name": "travel-crm-monorepo",
    "version": "1.0.0",
    "description": "Travel CRM full-stack application",
    "scripts": {
        "dev:backend": "cd travel-crm-backend && npm run dev",
        "dev:frontend": "cd frontend && npm run dev",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "build": "cd travel-crm-backend && npm run build && cd ../frontend && npm run build",
        "prisma:generate": "cd travel-crm-backend && npx prisma generate",
        "prisma:migrate": "cd travel-crm-backend && npx prisma migrate dev",
        "seed": "cd travel-crm-backend && npm run seed"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}